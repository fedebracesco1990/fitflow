{
  "name": "backend",
  "version": "1.0.0",
  "description": "FitFlow Backend API",
  "author": "",
  "private": true,
  "license": "MIT",
  "scripts": {
    "build": "nest build",
    "format": "prettier --write \"src/**/*.ts\"",
    "format:check": "prettier --check \"src/**/*.ts\"",
    "start": "nest start",
    "start:dev": "nest start --watch",
    "start:debug": "nest start --debug --watch",
    "start:prod": "node dist/main",
    "lint": "eslint \"src/**/*.ts\"",
    "lint:fix": "eslint \"src/**/*.ts\" --fix",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:cov": "jest --coverage",
    "test:debug": "node --inspect-brk -r tsconfig-paths/register -r ts-node/register node_modules/.bin/jest --runInBand",
    "typeorm": "typeorm-ts-node-commonjs",
    "migration:generate": "npm run typeorm -- migration:generate -d src/config/migrations.config.ts",
    "migration:run": "npm run typeorm -- migration:run -d src/config/migrations.config.ts",
    "migration:revert": "npm run typeorm -- migration:revert -d src/config/migrations.config.ts"
  },
  "dependencies": {
    "@nestjs/common": "11.1.8",
    "@nestjs/config": "4.0.2",
    "@nestjs/core": "11.0.1",
    "@nestjs/jwt": "11.0.1",
    "@nestjs/mapped-types": "*",
    "@nestjs/passport": "11.0.5",
    "@nestjs/platform-express": "11.0.1",
    "@nestjs/throttler": "6.5.0",
    "@nestjs/typeorm": "11.0.0",
    "bcrypt": "6.0.0",
    "class-transformer": "0.5.1",
    "class-validator": "0.14.2",
    "cookie-parser": "1.4.7",
    "helmet": "8.1.0",
    "joi": "18.0.1",
    "mysql2": "3.15.3",
    "passport": "0.7.0",
    "passport-jwt": "4.0.1",
    "passport-local": "1.0.0",
    "reflect-metadata": "0.2.2",
    "rxjs": "7.8.1",
    "typeorm": "0.3.27"
  },
  "devDependencies": {
    "@eslint/eslintrc": "3.2.0",
    "@eslint/js": "9.14.0",
    "@nestjs/cli": "11.0.10",
    "@nestjs/schematics": "11.0.3",
    "@nestjs/testing": "11.1.9",
    "@types/bcrypt": "6.0.0",
    "@types/cookie-parser": "1.4.10",
    "@types/express": "5.0.0",
    "@types/jest": "30.0.0",
    "@types/node": "22.8.6",
    "@types/passport-jwt": "4.0.1",
    "@types/passport-local": "1.0.38",
    "eslint": "9.39.1",
    "eslint-config-prettier": "10.1.8",
    "eslint-plugin-prettier": "5.5.4",
    "globals": "16.0.0",
    "jest": "30.2.0",
    "prettier": "3.3.3",
    "source-map-support": "0.5.21",
    "ts-jest": "29.4.5",
    "ts-loader": "9.5.1",
    "ts-node": "10.9.2",
    "tsconfig-paths": "4.2.0",
    "typescript": "5.8.2",
    "typescript-eslint": "8.11.0"
  }
}
